# ============================================================
# TriageBot environment variables
# Copy this file to ".env" and fill in your real values.
# NEVER commit your real .env file or hard-code keys in source.
# ============================================================

# Your OpenAI API key (required).
OPENAI_API_KEY=sk-your-key-here

# Model used by both the support agent and the LLM judge.
# Any chat model your key has access to works (e.g. gpt-4o-mini, gpt-4o).
TRIAGEBOT_MODEL=gpt-4o-mini

# Optional: override the OpenAI-compatible base URL (e.g. for Azure or a proxy).
# Leave unset to use the default OpenAI endpoint.
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: maximum number of self-review redo attempts before the bot
# escalates instead of looping forever. Defaults to 2.
TRIAGEBOT_MAX_REDOS=2
